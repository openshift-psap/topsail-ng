# FORGE Launcher Configuration
# Copy this file to launcher_config.yaml and customize as needed

forge_home: "~/forge"
forge_toolbox_name: "forge"  # Container name for toolbox
forge_toolbox_command: "bash"
container_image: "localhost/forge:latest"
container_file: "projects/core/image/Containerfile"
forge_image_extra_pkg: "vim git-core"

# Environment variables to export from current environment to the container
exported_env_vars:
  - KUBECONFIG
  # Add more environment variables as needed

# Custom environment variables (key/value pairs) to set in the container
custom_env_vars:
  # CUSTOM_CONFIG: "production"
  # DEBUG_LEVEL: "verbose"
